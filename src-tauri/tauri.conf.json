{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Inkdown",
  "version": "0.1.0",
  "identifier": "io.inkdown.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Inkdown",
        "width": 1120,
        "height": 760,
        "minWidth": 520,
        "minHeight": 400
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
