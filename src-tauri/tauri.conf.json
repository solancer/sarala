{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sarala",
  "version": "0.1.0",
  "identifier": "com.srinivasgowda.sarala",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sarala",
        "width": 1120,
        "height": 760,
        "minWidth": 520,
        "minHeight": 400,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "REPLACE_WITH_MINISIGN_PUBLIC_KEY",
      "endpoints": [
        "https://gist.githubusercontent.com/solancer/REPLACE_WITH_GIST_ID/raw/latest.json"
      ]
    }
  }
}
